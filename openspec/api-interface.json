{
  "info": {
    "title": "供應鏈與倉儲物流戰情室 API",
    "version": "1.0.0",
    "note": "目前前端使用 Mock Data 展示，此文件供 IT 工程師串接真實後端使用。"
  },
  "endpoints": [
    {
      "method": "POST",
      "path": "/api/auth/login",
      "description": "帳號登入（伺服器端代理呼叫 FME CheckUserId API，避免瀏覽器直接暴露帳密）",
      "request": { "USER_ID": "admin", "PSW": "admin123" },
      "response_success": {
        "MSG": "000 登入成功",
        "role": "admin",
        "name": "系統管理員",
        "warehouse": null,
        "token": "jwt-token-string"
      },
      "response_error": { "MSG": "100 帳號密碼錯誤" }
    },
    {
      "method": "GET",
      "path": "/api/sku",
      "description": "查詢庫存明細（支援 warehouse / category / status 篩選）",
      "query": { "warehouse": "北區倉", "category": "3C配件", "status": "缺貨" },
      "response": [
        {
          "id": "SKU0001",
          "name": "USB-C充電線",
          "category": "3C配件",
          "warehouse": "北區倉",
          "currentStock": 855,
          "safetyStock": 67,
          "avgDailyOutbound": 9.5,
          "daysOfStock": 90.0,
          "status": "呆滯",
          "updatedAt": "2026-07-01"
        }
      ]
    },
    {
      "method": "POST",
      "path": "/api/sku/import",
      "description": "Excel 上傳重繪庫存資料（multipart/form-data，欄位名 file）",
      "response_success": { "success": true, "importedRows": 24, "warnings": [] },
      "response_error": { "success": false, "message": "缺少必要欄位：目前庫存" }
    },
    {
      "method": "GET",
      "path": "/api/kpi/summary",
      "description": "取得五大 KPI 彙總數值",
      "response": {
        "turnoverDays": 30.5,
        "stockoutCount": 2,
        "staleCount": 7,
        "onTimeRatePct": 98.3,
        "pickingEfficiency": 119,
        "diffRatePct": 1.7,
        "lossValue": 38211
      }
    },
    {
      "method": "GET",
      "path": "/api/kpi/turnover-trend",
      "description": "近7天庫存週轉天數趨勢",
      "response": [{ "day": "週一", "turnoverDays": 18.2 }]
    },
    {
      "method": "GET",
      "path": "/api/kpi/picking-efficiency",
      "description": "近7天各班次揀貨效率",
      "response": [{ "day": "週一", "shift": "早班", "efficiency": 115 }]
    },
    {
      "method": "GET",
      "path": "/api/users",
      "description": "使用者權限清單（管理員權限）",
      "response": [
        { "id": "admin", "name": "系統管理員", "role": "admin", "warehouse": "全倉", "locked": false, "lastLogin": "2026-07-03 09:12" }
      ]
    },
    {
      "method": "PATCH",
      "path": "/api/users/{id}/lock",
      "description": "鎖定／解除鎖定帳號（管理員權限）",
      "request": { "locked": true },
      "response": { "success": true }
    },
    {
      "method": "PATCH",
      "path": "/api/users/{id}/role",
      "description": "變更使用者角色權限（管理員權限）",
      "request": { "role": "admin" },
      "response": { "success": true }
    },
    {
      "method": "GET",
      "path": "/api/dashboard-cards",
      "description": "取得儀表板卡片顯示設定",
      "response": [{ "id": 1, "name": "庫存週轉天數", "source": "WMS 庫存主檔", "refreshFreq": "每小時", "visible": true }]
    },
    {
      "method": "PUT",
      "path": "/api/dashboard-cards/{id}",
      "description": "更新儀表板卡片設定（管理員權限）",
      "request": { "name": "庫存週轉天數", "refreshFreq": "每日", "visible": true },
      "response": { "success": true }
    },
    {
      "method": "GET",
      "path": "/api/settings/thresholds",
      "description": "取得系統業務門檻設定",
      "response": {
        "turnoverWarn": 15, "turnoverDanger": 20, "staleDays": 45,
        "onTimeTarget": 98, "diffRateWarn": 1.0, "diffRateDanger": 2.0,
        "maxLoginAttempts": 5, "lockoutMinutes": 15
      }
    },
    {
      "method": "PUT",
      "path": "/api/settings/thresholds",
      "description": "更新系統業務門檻設定（管理員權限）",
      "request": { "turnoverWarn": 15, "turnoverDanger": 20 },
      "response": { "success": true }
    },
    {
      "method": "GET",
      "path": "/api/reports/export",
      "description": "匯出儀表板報告（PDF），實作上目前前端以 html2canvas + jsPDF 於前端直接產生",
      "query": { "format": "pdf" },
      "response": "binary/pdf"
    }
  ]
}
